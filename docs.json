          { "label": "Legend App", "href": "https://app.legend.trade" },
          { "label": "Arena", "href": "/arena" },
          { "label": "Fees", "href": "/about/fees" }
        ]
      },
      {
        "title": "Community",
        "items": [
          { "label": "X (Twitter)", "href": "https://x.com/legendtrade" },
          { "label": "Discord", "href": "https://discord.gg/tcy4pT7guV" }
