{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Legend Docs",
  "logo": "/logo.png",
  "colors": {
    "primary": "#ffa318",
    "light": "#ffa318",
    "dark": "#c77700"
  },
  "favicon": "/favicon-32x32.png",
