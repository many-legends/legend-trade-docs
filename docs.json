            "pages": [
              "arena/index",
              "arena/mechanics",
              "arena/wagers",
              "arena/queues"
            ]
          },
          {
            "group": "Rewards",
            "pages": [
              "rewards-and-points/referrals-and-rewards"
            ]
          },
          {
            "group": "Fees",
            "pages": [
